{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "default": "https://weme-ui.github.io/schema/v3/template.schema.json",
      "title": "Template Schema URL",
      "description": "The Schema URL, which should be `https://weme-ui.github.io/schema/v3/template.schema.json`",
      "examples": [
        "https://weme-ui.github.io/schema/v3/template.schema.json"
      ],
      "type": "string",
      "format": "uri"
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "title": "Template Name",
            "description": "The name of the template."
          },
          "description": {
            "title": "Template Description",
            "description": "The description of the template.",
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "src": {
                  "type": "string",
                  "title": "Template File Source",
                  "description": "The source of the template file.",
                  "examples": [
                    "templates/default/README.md"
                  ]
                },
                "dest": {
                  "type": "string",
                  "title": "Template File Destination",
                  "description": "The destination of the template file.",
                  "examples": [
                    "README.md"
                  ]
                }
              },
              "required": [
                "src",
                "dest"
              ],
              "additionalProperties": false
            },
            "title": "Template Files",
            "description": "The files of the template."
          }
        },
        "required": [
          "name",
          "files"
        ],
        "additionalProperties": false,
        "title": "Template",
        "description": "A variant of the template."
      },
      "title": "Templates",
      "description": "The templates of the skeleton."
    },
    "prompts": {
      "title": "Prompts",
      "description": "The prompts of the skeleton.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "text",
              "number",
              "confirm",
              "list",
              "select",
              "multiselect"
            ],
            "title": "Prompt Type",
            "description": "The type of the prompt."
          },
          "name": {
            "type": "string",
            "title": "Prompt Name",
            "description": "The name of the prompt."
          },
          "message": {
            "title": "Prompt Message",
            "description": "The message of the prompt.",
            "type": "string"
          },
          "initial": {
            "title": "Prompt Initial",
            "description": "The initial value of the prompt.",
            "type": "string"
          },
          "choices": {
            "title": "Prompt Choices",
            "description": "The choices of the prompt.",
            "examples": [
              [
                "default",
                "react",
                "vue"
              ]
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hint": {
            "title": "Prompt Hint",
            "description": "The hint of the prompt.",
            "examples": [
              "Enter your project name"
            ],
            "type": "string"
          }
        },
        "required": [
          "type",
          "name"
        ],
        "additionalProperties": false,
        "title": "Prompt",
        "description": "A variant of the prompt."
      }
    }
  },
  "required": [
    "$schema",
    "templates"
  ],
  "additionalProperties": false,
  "$id": "https://weme-ui.github.io/schema/v3/template.schema.json",
  "title": "Weme UI Skeleton Template JSON Schema Definitions (v3)",
  "description": "This schema defines the structure of the skeleton template JSON file used in Weme UI CLI `init` command."
}
