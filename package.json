{
  "name": "schema",
  "type": "module",
  "version": "1.0.0~dev",
  "packageManager": "pnpm@10.32.0",
  "author": "Allen Luo <luoyi@mouji.net>",
  "license": "MIT",
  "homepage": "https://weme-ui.github.io/schema",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weme-ui/schema.git"
  },
  "bugs": {
    "url": "https://github.com/weme-ui/schema/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10.13.0"
  },
  "scripts": {
    "build": "pnpm run build:v1 && pnpm run build:v2",
    "build:v1": "premove ./docs/v1 && jsonschema2md -d ./src/v1 -x ./v1 -o ./docs/v1",
    "build:v2": "premove ./docs/v2 && jsonschema2md -d ./src/v2 -x ./v2 -o ./docs/v2",
    "clean": "premove ./v1 ./v2 ./docs/v1 ./docs/v2",
    "taze": "taze major -I -r"
  },
  "devDependencies": {
    "@adobe/jsonschema2md": "^8.0.10",
    "premove": "^4.0.0",
    "taze": "^19.10.0"
  }
}
